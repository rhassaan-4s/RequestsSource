	<bean id="hikariConfig" class="com.zaxxer.hikari.HikariConfig">
	    <property name="poolName" value="springHikariCP" />
	    <property name="connectionTestQuery" value="SELECT 1 from dual" />
	    <property name="dataSourceClassName" value="${hibernate.connection.dataSourceClassName}" />
	    <property name="maximumPoolSize" value="${hibernate.hikari.maximumPoolSize}" />
	    <property name="idleTimeout" value="${hibernate.hikari.idleTimeout}" />
	    
	    <property name="minimumIdle" value="${hibernate.hikari.minimumIdle}" />
	    <property name="maxLifetime" value="${hibernate.hikari.maxLifetime}" />
	    <property name="connectionTimeout" value="${hibernate.hikari.connectionTimeout}"/>
	    <property name="validationTimeout" value="${hibernate.hikari.validationTimeout}"/>
	
	    <property name="dataSourceProperties">
	        <props>
	            <prop key="url">${hibernate.connection.url}</prop>
	            <prop key="user">${hibernate.connection.username}</prop>
	            <prop key="password">${hibernate.connection.password}</prop>
	        </props>
	    </property>
	</bean>
	
	<!-- HikariCP configuration -->
	<bean id="dataSource" class="com.zaxxer.hikari.HikariDataSource" destroy-method="close">
	    <constructor-arg ref="hikariConfig" />
	</bean>

