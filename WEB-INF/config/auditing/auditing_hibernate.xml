		<bean id="hikariConfig" class="com.zaxxer.hikari.HikariConfig">
		    <property name="poolName" value="springHikariCP" />
		    <property name="connectionTestQuery" value="SELECT 1 from dual" />
		    <property name="dataSourceClassName" value="${hibernate.connection.dataSourceClassName}" />
		    <property name="maximumPoolSize" value="${hibernate.hikari.maximumPoolSize}" />
		    <property name="idleTimeout" value="${hibernate.hikari.idleTimeout}" />
		    
		    <property name="minimumIdle" value="${hibernate.hikari.minimumIdle}" />
		    <property name="maxLifetime" value="${hibernate.hikari.maxLifetime}" />
		    <property name="connectionTimeout" value="${hibernate.hikari.connectionTimeout}"/>
		    <property name="validationTimeout" value="${hibernate.hikari.validationTimeout}"/>
	
	    <property name="dataSourceProperties">
	        <props>
	            <prop key="url">${hibernate.connection.url}</prop>
	            <prop key="user">${hibernate.connection.username}</prop>
	            <prop key="password">${hibernate.connection.password}</prop>
	        </props>
	    </property>
	</bean>
	<!-- HikariCP configuration -->
	<bean id="auditingDataSource" class="com.zaxxer.hikari.HikariDataSource" destroy-method="close">
	    <constructor-arg ref="hikariConfig" />
	</bean>

	<!-- Hibernate SessionFactory -->
	<bean id="auditSessionFactory" class="org.springframework.orm.hibernate5.LocalSessionFactoryBean">
		<property name="dataSource" ref="auditingDataSource" />
		<property name="packagesToScan">
			<list>
				<value>com._4s_.HR.model</value>
				<value>com._4s_.auditing.model</value>
				<value>com._4s_.common.model</value>
				<value>com._4s_.dbUpdate.model</value>
				<value>com._4s_.security.model</value>
				<value>com._4s_.i18n.model</value>
				<value>com._4s_.requestsApproval.model</value>
				<value>com._4s_.timesheet.model</value>
				<value>com._4s_.attendance.model</value>
			</list>
		</property>

		<property name="hibernateProperties">
			<props>
			<prop key="hibernate.dialect">${hibernate.dialect}</prop>
  			<prop key="hibernate.show_sql">true</prop>  
  			
  			<prop key="hibernate.multiTenancy">
					SCHEMA
				</prop>
				<prop key="hibernate.multi_tenant_connection_provider">
					com._4s_.common.dao.SchemaMultiTenantConnectionProvider
				</prop>
				<prop key="hibernate.tenant_identifier_resolver">
					com._4s_.common.dao.CurrentTenantIdentifierResolverImpl
				</prop>
				
			</props>
		</property>
	</bean>
	
	<bean id="auditTransactionManager"
		class="org.springframework.orm.hibernate5.HibernateTransactionManager"  lazy-init="true">
		<property name="sessionFactory" ref="auditSessionFactory" />
	</bean>

	<bean id="auditTxProxyTemplate" abstract="true"
		class="org.springframework.transaction.interceptor.TransactionProxyFactoryBean">
		<property name="transactionManager" ref ="auditTransactionManager" />
		<property name="transactionAttributes">
			<props>
				<prop key="save*">PROPAGATION_REQUIRED,ISOLATION_SERIALIZABLE</prop>
				<prop key="remove*">PROPAGATION_REQUIRED,ISOLATION_SERIALIZABLE</prop>
				<prop key="*">PROPAGATION_REQUIRED,ISOLATION_SERIALIZABLE,readOnly</prop>
			</props>
		</property>
	</bean>

	
</beans>