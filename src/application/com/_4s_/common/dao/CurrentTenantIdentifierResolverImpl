package com._4s_.common.dao;

import java.io.IOException;
import java.util.Properties;
import javax.servlet.http.HttpSession;

import org.apache.commons.logging.Log;
import org.apache.commons.logging.LogFactory;
import org.hibernate.context.spi.CurrentTenantIdentifierResolver;
import org.springframework.web.context.request.RequestContextHolder;
import org.springframework.web.context.request.ServletRequestAttributes;

/**
 * Resolves the current tenant identifier for Hibernate sessions.
 * Can resolve from ThreadLocal or HTTP session, or fall back to default.
 */
public class CurrentTenantIdentifierResolverImpl implements CurrentTenantIdentifierResolver {

    private static final String KEY_TENANTID_SESSION = "tenantID";
    private static final ThreadLocal<String> CURRENT_TENANT = new ThreadLocal<>();

    private String defaultTenant;

    private final Log logger = LogFactory.getLog(getClass());

    public CurrentTenantIdentifierResolverImpl() {
        try {
            // Load properties to get default tenant from hibernate.properties
            Properties props = new Properties();
            props.load(getClass().getResourceAsStream("/hibernate.properties"));

            String defaultUser = props.getProperty("hibernate.connection.username");
            if (defaultUser == null) {
                throw new RuntimeException("Default tenant not configured in hibernate.properties");
            }
            this.defaultTenant = defaultUser;
            logger.debug("Default tenant loaded: " + defaultTenant);

        } catch (IOException e) {
            throw new RuntimeException("Failed to load hibernate.properties", e);
        }
    }

    /** Set tenant for current thread */
    public static void setTenant(String tenantId) {
        CURRENT_TENANT.set(tenantId);
    }

    /** Get tenant for current thread */
    public static String getTenant() {
        return CURRENT_TENANT.get();
    }

    /** Clear tenant for current thread */
    public static void clear() {
        CURRENT_TENANT.remove();
    }

    @Override
    public String resolveCurrentTenantIdentifier() {
        String tenant = CURRENT_TENANT.get();
        logger.debug("*****************Resolving tenant. ThreadLocal tenant: " + tenant);
        if (tenant != null) {
            logger.debug("*****************Tenant resolved from ThreadLocal: " + tenant);
            return tenant;
        } else {
			logger.debug("*****************No tenant in ThreadLocal, checking HTTP session...");
		}

        // Attempt to resolve tenant from HTTP session
        ServletRequestAttributes attr = (ServletRequestAttributes) RequestContextHolder.getRequestAttributes();
        if (attr != null) {
            HttpSession session = attr.getRequest().getSession(false);
            if (session != null) {
                Object sessionTenant = session.getAttribute(KEY_TENANTID_SESSION);
                if (sessionTenant != null) {
                    tenant = sessionTenant.toString();
                    logger.debug("Tenant resolved from HTTP session: " + tenant);
                    return tenant;
                }
            }
        }

        // Fallback to default tenant
        logger.debug("No tenant found in ThreadLocal or session, using default: " + defaultTenant);
        return defaultTenant;
    }

    @Override
    public boolean validateExistingCurrentSessions() {
        return true;
    }
}

